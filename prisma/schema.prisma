// Alrit.dev — esquema CMS v1.
// Patrón OVERRIDES: el contenido en código es el default; aquí solo vive lo editado.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth (Auth.js Credentials, single-tenant) ----------
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role // sin default: se fija explícito (seed=ADMIN, registro=STUDENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  enrollments  Enrollment[]
  progress     LessonProgress[]
  clientProjects   ClientProject[]  @relation("ClientProjects")
  authoredComments ProjectComment[] @relation("AuthoredComments")
  createdIssues    Issue[]          @relation("CreatedIssues")
}

enum Role {
  ADMIN
  EDITOR
  STUDENT
  CLIENT
}

// ---------- Precios (M1) — sembrado de lib/pricing.ts ----------
model PricingType {
  id        String   @id // "landing" | "ecommerce" | "lms" | "realestate" | "mobile" | "custom"
  base      Int? // MXN; null => proyecto a medida
  weeks     String? // null para proyectos a medida
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
}

model PricingExtra {
  id        String   @id // "multilang" | "blog" | "payments" | "seo"
  price     Int
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
}

// ---------- Portafolio (M3) — sembrado de portfolio.data.json ----------
model Project {
  id             String   @id @default(cuid())
  slug           String   @unique
  image          String
  imageMobile    String
  bg             String
  cat            String
  relatedService String
  url            String
  status         String
  industry       String   @db.Text
  tech           String   @db.Text
  locales        Json // { es:{title,short,long}, en:{...} }
  highlights     Json // string[]
  tags           Json // string[]
  sortOrder      Int      @default(0)
  featured       Boolean  @default(false)
  accent         String?
  icon           String?
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ---------- Textos curados (M4) — solo lo cambiado ----------
model TextOverride {
  id        String   @id @default(cuid())
  key       String // dotted path: "hero.titleAccent"
  locale    Locale
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
}

enum Locale {
  es
  en
}

// ---------- Biblioteca de medios (M2) — MinIO ----------
model Media {
  id        String      @id @default(cuid())
  filename  String
  objectKey String      @unique
  url       String
  alt       String?
  mime      String
  width     Int?
  height    Int?
  bytes     Int?
  createdAt DateTime    @default(now())
  slots     MediaSlot[]
}

model MediaSlot {
  slot      String   @id // id del catálogo de slots (lib/slots.ts)
  mediaId   String
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Restrict)
  updatedAt DateTime @updatedAt

  @@index([mediaId])
}

// ---------- LMS (cursos, inscripción, progreso) ----------
model Course {
  id          String       @id @default(cuid())
  slug        String       @unique
  language    String       @default("es")
  title       String
  summary     String       @db.Text
  description String       @db.Text
  coverImage  String?
  level       String       @default("intro")
  priceCents  Int          @default(0) // 0 = gratis (reservado para Stripe)
  published   Boolean      @default(false)
  sortOrder   Int          @default(0)
  sections    Section[]
  enrollments Enrollment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Section {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  sortOrder Int      @default(0)
  lessons   Lesson[]

  @@index([courseId])
}

model Lesson {
  id          String           @id @default(cuid())
  sectionId   String
  section     Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title       String
  videoUrl    String?
  content     String?          @db.Text
  durationMin Int?
  preview     Boolean          @default(false)
  sortOrder   Int              @default(0)
  progress    LessonProgress[]

  @@index([sectionId])
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([courseId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([userId, lessonId])
  @@index([userId])
}

// ---------- Portal de clientes ----------
enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
}

model ClientProject {
  id        String           @id @default(cuid())
  name      String
  clientId  String
  client    User             @relation("ClientProjects", fields: [clientId], references: [id], onDelete: Cascade)
  summary   String?          @db.Text
  status    String           @default("en progreso")
  phases    Phase[]
  updates   ProjectUpdate[]
  comments  ProjectComment[]
  issues    Issue[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([clientId])
}

model Phase {
  id        String        @id @default(cuid())
  projectId String
  project   ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  done      Boolean       @default(false)
  sortOrder Int           @default(0)

  @@index([projectId])
}

model ProjectUpdate {
  id        String        @id @default(cuid())
  projectId String
  project   ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  body      String        @db.Text
  createdAt DateTime      @default(now())

  @@index([projectId])
}

model ProjectComment {
  id        String        @id @default(cuid())
  projectId String
  project   ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation("AuthoredComments", fields: [authorId], references: [id], onDelete: Cascade)
  body      String        @db.Text
  createdAt DateTime      @default(now())

  @@index([projectId])
}

model Issue {
  id          String        @id @default(cuid())
  projectId   String
  project     ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?       @db.Text
  priority    IssuePriority @default(MEDIUM)
  status      IssueStatus   @default(OPEN)
  createdById String
  createdBy   User          @relation("CreatedIssues", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([projectId])
}

// ---------- Cotizaciones (leads de la calculadora) ----------
enum QuoteStatus {
  NEW
  CONTACTED
  CLOSED
}

model Quote {
  id          String      @id @default(cuid())
  name        String
  email       String
  phone       String?
  brief       String?     @db.Text
  projectType String // ProjectTypeId
  extras      Json // ExtraId[]
  amount      Int? // MXN (pesos); null = a medida
  custom      Boolean     @default(false)
  status      QuoteStatus @default(NEW)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ---------- Logos editables (marcas + tecnologías) ----------
enum LogoGroup {
  BRAND
  TECH
}

model Logo {
  id        String    @id @default(cuid())
  name      String
  image     String
  group     LogoGroup
  sortOrder Int       @default(0)
  published Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([group])
}

// ---------- Blog (artículos en Markdown, bilingüe, SEO) ----------
model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  category    String
  cover       String?
  author      String    @default("Equipo Alrit")
  locales     Json // { es:{title,excerpt,body}, en:{...} } — body = Markdown
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
  @@index([category, published, publishedAt])
}

// ---------- Configuración del sitio (singleton, editable en el admin) ----------
model SiteSettings {
  id              String   @id @default("site")
  email           String   @default("")
  whatsapp        String   @default("") // solo dígitos, formato internacional (wa.me/<whatsapp>)
  phone           String   @default("") // E.164 con + (tel: y schema telephone)
  streetAddress   String   @default("")
  addressLocality String   @default("")
  addressRegion   String   @default("")
  postalCode      String   @default("")
  addressCountry  String   @default("MX")
  instagram       String   @default("")
  linkedin        String   @default("")
  github          String   @default("")
  facebook        String   @default("")
  x               String   @default("")
  gaId            String   @default("") // GA4 Measurement ID (G-XXXX)
  priceRange      String   @default("$$")
  updatedAt       DateTime @updatedAt
}
