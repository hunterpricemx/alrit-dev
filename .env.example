# Copia este archivo a .env y rellena los valores reales.
# .env está gitignored — NUNCA commitees secretos ni contraseñas en claro.

# ---------- Base de datos (la web en Docker apunta al servicio `db`) ----------
DATABASE_URL="postgresql://alrit:alrit@db:5432/alrit?schema=public"
POSTGRES_USER=alrit
POSTGRES_PASSWORD=alrit
POSTGRES_DB=alrit

# ---------- Auth.js v5 ----------
# Genera el secreto:  openssl rand -base64 32
AUTH_SECRET=changeme-genera-uno-con-openssl
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
# Usuario admin que se siembra en la DB.
ADMIN_EMAIL=mariano@hunterprice.mx
ADMIN_NAME=Mariano
# Hash bcrypt de la contraseña (NUNCA la contraseña en claro). Genéralo con:
# node -e "console.log(require('bcryptjs').hashSync('TU_PASSWORD',10))"
ADMIN_PASSWORD_HASH='$2b$10$replace-with-your-bcrypt-hash'

# ---------- MinIO / S3 (biblioteca de medios, M2) ----------
# S3_ENDPOINT: lo usa el servidor (servicio `minio`). S3_PUBLIC_URL: lo ve el navegador.
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000/alrit-media
S3_REGION=us-east-1
S3_BUCKET=alrit-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Analítica (opcional): GA4 Measurement ID. Sin esto, la analítica queda inerte.
NEXT_PUBLIC_GA_ID=
